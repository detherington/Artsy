    <item>
        <title>Version 0.2.0</title>
        <pubDate>Sat, 18 Apr 2026 00:26:53 +0000</pubDate>
        <sparkle:version>2</sparkle:version>
        <sparkle:shortVersionString>0.2.0</sparkle:shortVersionString>
        <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
        <description><![CDATA[
            <ul>
                <li>Configurable canvas + brush defaults in Settings → General</li>
                <li>Custom in-app color picker with recent colors and presets</li>
                <li>Auto-update via Sparkle (first release with updater)</li>
                <li>Unsaved-changes prompt before quit, with window dot + tab-bar bullet</li>
                <li>Much faster save — GPU-batched + non-blocking PNG encoding</li>
            </ul>
        ]]></description>
